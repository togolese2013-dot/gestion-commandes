---
import '../styles/global.css';
import { getCurrentUser } from '../lib/auth';

interface Props {
  title: string;
  isAdmin?: boolean;
}

const { title, isAdmin = false } = Astro.props;
const currentUser = isAdmin ? getCurrentUser(Astro.request) : null;
const isAdminRole = currentUser?.role === 'admin';
---

<!doctype html>
<html lang="fr" style="overflow-x:hidden;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Gestion Commandes</title>
    <!-- Apply dark mode before paint to avoid flash -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900 overflow-x-hidden">
    {isAdmin && (
      <header class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <!-- Row 1: logo + search + user -->
          <div class="flex items-center gap-4 h-12">
            <span class="font-bold text-sm text-blue-700 shrink-0 tracking-tight">Gestion Commandes</span>
            <!-- Global search: fills all available space -->
            <div class="flex-1 relative hidden sm:block">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
              </svg>
              <input
                id="global-search"
                type="text"
                autocomplete="off"
                placeholder="Rechercher… (commandes, clients)"
                class="w-full pl-9 pr-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50 focus:bg-white transition"
              />
              <div id="global-results" class="absolute z-30 left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg hidden overflow-hidden min-w-[320px]"></div>
            </div>
            <div class="flex-1 sm:hidden"></div>
            <!-- Right actions -->
            <div class="flex items-center gap-1 shrink-0">
              {currentUser && (
                <button
                  id="profile-btn"
                  class="text-xs font-medium text-gray-700 hover:text-blue-700 transition-colors whitespace-nowrap cursor-pointer px-2 py-1.5 rounded-lg hover:bg-gray-100"
                  data-id={currentUser.id}
                  data-name={currentUser.full_name}
                >
                  👤 <span class="hidden md:inline">{currentUser.full_name}</span>
                </button>
              )}
              <button id="dark-toggle" type="button" title="Mode sombre"
                class="text-gray-400 hover:text-gray-700 transition-colors p-1.5 rounded-lg hover:bg-gray-100">
                <svg id="icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
                </svg>
                <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                </svg>
              </button>
              <form action="/api/auth/logout" method="POST" style="display:flex;align-items:center;">
                <button type="submit" class="text-xs text-gray-400 hover:text-red-600 transition-colors whitespace-nowrap px-2 py-1.5 rounded-lg hover:bg-gray-100">
                  Déconnexion
                </button>
              </form>
            </div>
          </div>
          <!-- Row 2: nav -->
          <nav class="flex items-center gap-1 text-sm font-medium overflow-x-auto scrollbar-none -mx-1 px-1">
            <a href="/admin/dashboard" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap">Dashboard</a>
            <a href="/admin" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap">+ Nouvelle</a>
            <a href="/admin/orders" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap flex items-center gap-1.5">
              Commandes
              <span id="pending-badge" class="hidden items-center justify-center min-w-[18px] h-[18px] px-1 bg-red-500 text-white text-[10px] font-bold rounded-full leading-none"></span>
            </a>
            <a href="/admin/clients" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap">Clients</a>
            {isAdminRole && (
              <a href="/admin/payments" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap">Paiements</a>
            )}
            {isAdminRole && (
              <a href="/admin/settings" class="nav-link py-2 px-3 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors whitespace-nowrap">Paramètres</a>
            )}
          </nav>
        </div>
      </header>
    )}

    <!-- Profile edit modal -->
    {isAdmin && currentUser && (
      <div id="profile-modal" class="fixed inset-0 bg-black/40 flex items-center justify-center z-50 hidden">
        <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-sm mx-4">
          <h2 class="text-base font-semibold text-gray-900 mb-4">Mon profil</h2>
          <form id="profile-form" class="space-y-3">
            <input type="hidden" name="id" value={currentUser.id} />
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Nom complet</label>
              <input type="text" name="full_name" required value={currentUser.full_name}
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Nouveau mot de passe</label>
              <input type="password" name="password" placeholder="Laisser vide pour ne pas changer"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <p id="profile-error" class="text-sm text-red-600 hidden"></p>
            <p id="profile-success" class="text-sm text-green-600 hidden">Modifications enregistrées ✓</p>
            <div class="flex gap-2 pt-1">
              <button type="submit"
                class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors">
                Enregistrer
              </button>
              <button type="button" id="profile-cancel"
                class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold py-2 rounded-lg transition-colors">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>
    )}

    <main class="max-w-7xl mx-auto px-3 sm:px-4 py-6 sm:py-8 w-full overflow-x-hidden">
      <slot />
    </main>

    <!-- Toast container -->
    <div id="toast-container"></div>

    <!-- Dark mode toggle + global toast function -->
    <script is:inline>
      // ── Active nav link ───────────────────────────────────────────────────
      (function () {
        var path = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(function (a) {
          var href = a.getAttribute('href');
          if (!href) return;
          // exact match or sub-path (but /admin must be exact to avoid matching everything)
          var active = href === '/admin' ? path === '/admin' : path === href || path.startsWith(href + '/');
          if (active) a.classList.add('active');
        });
      })();

      // ── Dark mode icons ───────────────────────────────────────────────────
      (function () {
        const moonIcon = document.getElementById('icon-moon');
        const sunIcon  = document.getElementById('icon-sun');
        function updateIcons() {
          const dark = document.documentElement.classList.contains('dark');
          if (moonIcon) moonIcon.classList.toggle('hidden', dark);
          if (sunIcon)  sunIcon.classList.toggle('hidden', !dark);
        }
        updateIcons();
        document.getElementById('dark-toggle')?.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcons();
        });
      })();

      // ── Toast notifications ───────────────────────────────────────────────
      window.__showToast = function (message, type, duration) {
        type     = type     || 'info';
        duration = duration || 3500;
        var container = document.getElementById('toast-container');
        if (!container) return;
        var icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' };
        var toast = document.createElement('div');
        toast.className = 'toast toast-' + type;
        toast.innerHTML = '<span>' + (icons[type] || '') + '</span><span>' + message + '</span>';
        container.appendChild(toast);
        setTimeout(function () {
          toast.classList.add('hide');
          toast.addEventListener('animationend', function () { toast.remove(); }, { once: true });
        }, duration);
      };
    </script>

    {isAdmin && currentUser && (
      <script>
        const modal   = document.getElementById('profile-modal')!;
        const form    = document.getElementById('profile-form') as HTMLFormElement;
        const errEl   = document.getElementById('profile-error')!;
        const okEl    = document.getElementById('profile-success')!;

        document.getElementById('profile-btn')?.addEventListener('click', () => {
          errEl.classList.add('hidden');
          okEl.classList.add('hidden');
          (form.querySelector('[name=password]') as HTMLInputElement).value = '';
          modal.classList.remove('hidden');
        });

        document.getElementById('profile-cancel')?.addEventListener('click', () => modal.classList.add('hidden'));
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          errEl.classList.add('hidden');
          okEl.classList.add('hidden');
          const id        = (form.querySelector('[name=id]') as HTMLInputElement).value;
          const full_name = (form.querySelector('[name=full_name]') as HTMLInputElement).value.trim();
          const password  = (form.querySelector('[name=password]') as HTMLInputElement).value.trim();

          const body: Record<string, string> = { full_name };
          if (password) body.password = password;

          const res = await fetch(`/api/users/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });

          if (res.ok) {
            okEl.classList.remove('hidden');
            // Update displayed name in header
            const btn = document.getElementById('profile-btn');
            if (btn) btn.textContent = '👤 ' + full_name;
            setTimeout(() => modal.classList.add('hidden'), 1000);
          } else {
            const err = await res.json();
            errEl.textContent = err.error ?? 'Erreur';
            errEl.classList.remove('hidden');
          }
        });

        // ── Badge commandes en attente ────────────────────────────────────────
        async function updatePendingBadge() {
          try {
            const res = await fetch('/api/orders/count');
            if (!res.ok) return;
            const { en_attente } = await res.json();
            const badge = document.getElementById('pending-badge');
            if (!badge) return;
            if (en_attente > 0) {
              badge.textContent = en_attente > 99 ? '99+' : String(en_attente);
              badge.classList.remove('hidden');
              badge.classList.add('inline-flex');
            } else {
              badge.classList.add('hidden');
              badge.classList.remove('inline-flex');
            }
          } catch { /* silent */ }
        }
        updatePendingBadge();
        setInterval(updatePendingBadge, 30_000);

        // ── Recherche globale ─────────────────────────────────────────────────
        const globalSearch  = document.getElementById('global-search') as HTMLInputElement | null;
        const globalResults = document.getElementById('global-results')!;

        const statusIcon: Record<string, string> = {
          en_attente: '⏳',
          disponible: '✅',
          recupere:   '📦',
        };

        function esc(s: string) {
          return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function renderGlobalResults(data: { orders: any[]; clients: any[] }) {
          const { orders, clients } = data;
          if (!orders.length && !clients.length) {
            globalResults.innerHTML = '<div class="px-4 py-3 text-sm text-gray-400">Aucun résultat</div>';
            globalResults.classList.remove('hidden');
            return;
          }
          let html = '';
          if (orders.length) {
            html += `<div class="px-3 py-1.5 text-[10px] font-bold text-gray-400 uppercase tracking-wider bg-gray-50 border-b border-gray-100">Commandes</div>`;
            html += orders.map((o: any) => `
              <a href="/admin/orders" data-order="${esc(o.order_number)}"
                class="search-order-link flex items-center justify-between gap-3 px-4 py-2.5 hover:bg-blue-50 transition-colors border-b border-gray-50">
                <div>
                  <span class="font-mono text-xs font-bold text-blue-700">${esc(o.order_number)}</span>
                  <span class="ml-2 text-sm text-gray-700">${esc(o.client_name)}</span>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs">${statusIcon[o.status] ?? ''}</span>
                  <span class="text-xs text-gray-500 font-semibold">${Number(o.total_amount).toLocaleString('fr-FR')} F</span>
                </div>
              </a>`).join('');
          }
          if (clients.length) {
            html += `<div class="px-3 py-1.5 text-[10px] font-bold text-gray-400 uppercase tracking-wider bg-gray-50 border-b border-gray-100 ${orders.length ? 'border-t border-gray-200' : ''}">Clients</div>`;
            html += clients.map((c: any) => `
              <a href="/admin/clients"
                class="flex items-center justify-between gap-3 px-4 py-2.5 hover:bg-blue-50 transition-colors border-b border-gray-50">
                <span class="text-sm font-medium text-gray-900">${esc(c.name)}</span>
                <span class="text-xs text-gray-400 font-mono">${esc(c.phone)}</span>
              </a>`).join('');
          }
          globalResults.innerHTML = html;
          globalResults.classList.remove('hidden');
        }

        let searchTimer: ReturnType<typeof setTimeout>;
        globalSearch?.addEventListener('input', () => {
          clearTimeout(searchTimer);
          const q = globalSearch.value.trim();
          if (q.length < 2) { globalResults.classList.add('hidden'); return; }
          searchTimer = setTimeout(async () => {
            try {
              const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
              if (res.ok) renderGlobalResults(await res.json());
            } catch { /* silent */ }
          }, 200);
        });

        globalSearch?.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') { globalResults.classList.add('hidden'); globalSearch.blur(); }
        });

        document.addEventListener('click', (e) => {
          if (!globalSearch?.contains(e.target as Node) && !globalResults.contains(e.target as Node)) {
            globalResults.classList.add('hidden');
          }
        });

        // ── Raccourcis clavier ────────────────────────────────────────────────
        document.addEventListener('keydown', (e) => {
          const tag = (e.target as HTMLElement).tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          switch (e.key.toLowerCase()) {
            case 'n': window.location.href = '/admin'; break;
            case 'o': window.location.href = '/admin/orders'; break;
            case 'c': window.location.href = '/admin/clients'; break;
          }
        });
      </script>
    )}
  </body>
</html>
