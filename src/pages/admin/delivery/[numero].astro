---
import { requireAuth } from '../../../lib/auth';
import { getOrderByNumber } from '../../../lib/orders';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const { numero } = Astro.params;
const order = numero ? getOrderByNumber(numero) : null;

const fmt = (n: number) => n.toLocaleString('fr-FR');
const dateStr = (d: string) => new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
const todayStr = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bon de livraison {order?.order_number ?? 'introuvable'}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
      font-size: 13px;
      color: #111;
      background: #f3f4f6;
    }

    /* Print action bar */
    .no-print {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #166534;
      padding: 10px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    .no-print button {
      background: #fff;
      color: #166534;
      border: none;
      border-radius: 6px;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .no-print button:hover { background: #dcfce7; }
    .no-print a {
      color: #bbf7d0;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
    }
    .no-print a:hover { color: #fff; }
    .no-print .spacer { flex: 1; }
    .no-print .hint {
      color: #86efac;
      font-size: 12px;
    }

    /* A4 page wrapper */
    .page-wrapper {
      display: flex;
      justify-content: center;
      padding: 24px 16px 48px;
    }

    .page {
      background: #fff;
      width: 100%;
      max-width: 800px;
      min-height: 1100px;
      padding: 40px 48px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      border-radius: 4px;
    }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 6px;
    }
    .company-name {
      font-size: 30px;
      font-weight: 900;
      color: #166534;
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .company-tagline {
      font-size: 11px;
      color: #6b7280;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-top: 4px;
      text-align: center;
    }
    .company-contact {
      text-align: right;
      font-size: 11.5px;
      color: #374151;
      line-height: 1.7;
    }
    .company-contact strong {
      color: #166534;
      font-weight: 700;
    }

    /* Separator */
    .divider {
      height: 3px;
      background: linear-gradient(90deg, #166534 0%, #16a34a 60%, #bbf7d0 100%);
      border-radius: 2px;
      margin: 14px 0;
    }

    /* Document title row */
    .doc-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .doc-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #166534;
      color: #fff;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 1.5px;
      padding: 8px 18px;
      border-radius: 6px;
      text-transform: uppercase;
    }
    .order-number-badge {
      font-family: 'Courier New', Courier, monospace;
      font-size: 15px;
      font-weight: 700;
      color: #166534;
      background: #f0fdf4;
      border: 1.5px solid #bbf7d0;
      padding: 5px 12px;
      border-radius: 5px;
      letter-spacing: 0.5px;
    }
    .doc-date {
      font-size: 12px;
      color: #6b7280;
      text-align: right;
    }
    .doc-date strong {
      display: block;
      font-size: 13.5px;
      color: #111;
    }

    /* Info grid */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 22px;
    }
    .info-box {
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      overflow: hidden;
    }
    .info-box-header {
      background: #f8fafc;
      border-bottom: 1px solid #e5e7eb;
      padding: 7px 14px;
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #6b7280;
    }
    .info-box-body {
      padding: 12px 14px;
      line-height: 1.8;
    }
    .info-box-body .label {
      font-size: 10.5px;
      color: #9ca3af;
      font-weight: 600;
      text-transform: uppercase;
    }
    .info-box-body .value {
      font-size: 13px;
      color: #111;
      font-weight: 600;
    }
    .info-box-body .value.big {
      font-size: 15px;
      font-weight: 700;
      color: #166534;
      text-transform: uppercase;
    }
    .delivery-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
    }
    .delivery-avion {
      background: #eff6ff;
      color: #1e40af;
      border: 1px solid #bfdbfe;
    }
    .delivery-bateau {
      background: #f0fdf4;
      color: #166534;
      border: 1px solid #bbf7d0;
    }

    /* Products table */
    .section-title {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #6b7280;
      margin-bottom: 8px;
      padding-bottom: 4px;
      border-bottom: 1px solid #e5e7eb;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      font-size: 12.5px;
    }
    thead tr {
      background: #166534;
      color: #fff;
    }
    thead th {
      padding: 9px 12px;
      text-align: left;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    thead th:last-child { text-align: right; }
    thead th:nth-child(1) { text-align: center; width: 44px; }
    tbody tr:nth-child(even) { background: #f8fafc; }
    tbody tr:nth-child(odd) { background: #fff; }
    tbody td {
      padding: 9px 12px;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: top;
      color: #1f2937;
    }
    tbody td:first-child { text-align: center; color: #6b7280; font-weight: 600; }
    tbody td:last-child { text-align: right; font-weight: 600; color: #111; }
    tfoot tr { background: #f0fdf4; }
    tfoot td {
      padding: 9px 12px;
      font-weight: 700;
      color: #166534;
      text-align: right;
      font-size: 13px;
      border-top: 2px solid #bbf7d0;
    }
    tfoot td:first-child { text-align: center; color: #166534; }
    tfoot td:nth-child(2) { text-align: left; }
    .product-name { font-weight: 600; color: #111; }
    .product-condition {
      font-size: 10.5px;
      color: #9ca3af;
      margin-top: 1px;
    }

    /* Signature zone */
    .signature-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 32px;
      margin-bottom: 28px;
    }
    .signature-box {
      border: 1.5px dashed #d1d5db;
      border-radius: 6px;
      padding: 14px 16px;
      min-height: 110px;
      display: flex;
      flex-direction: column;
    }
    .signature-box-title {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #6b7280;
      margin-bottom: 8px;
    }
    .signature-box-hint {
      font-size: 10px;
      color: #d1d5db;
      font-style: italic;
      margin-top: auto;
    }
    .signature-line {
      border-bottom: 1px solid #e5e7eb;
      margin-top: 40px;
    }
    .date-line {
      font-size: 11px;
      color: #9ca3af;
      margin-top: 6px;
    }

    /* Footer */
    .footer {
      text-align: center;
      padding-top: 16px;
      border-top: 1px solid #e5e7eb;
      color: #9ca3af;
      font-size: 11.5px;
    }
    .footer strong {
      display: block;
      font-size: 13px;
      color: #374151;
      font-weight: 700;
      margin-bottom: 3px;
    }

    /* Error page */
    .error-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 300px;
      gap: 12px;
      color: #6b7280;
    }
    .error-page h2 {
      font-size: 20px;
      color: #374151;
      font-weight: 700;
    }

    /* ===== PRINT STYLES ===== */
    @media print {
      .no-print { display: none !important; }

      body {
        background: #fff;
        font-size: 11px;
      }

      .page-wrapper { padding: 0; }

      .page {
        max-width: 100%;
        width: 100%;
        min-height: auto;
        box-shadow: none;
        padding: 20mm 18mm;
        border-radius: 0;
      }

      .company-name { font-size: 24px; }
      table { font-size: 11px; }
      thead th { font-size: 10px; }

      @page {
        size: A4;
        margin: 0;
      }
    }
  </style>
</head>
<body>

  <!-- Print action bar (hidden on print) -->
  <div class="no-print">
    <button onclick="window.print()">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Imprimer
    </button>
    <a href="/admin/orders">← Retour aux commandes</a>
    <span class="spacer"></span>
    {order && <span class="hint">Commande {order.order_number}</span>}
  </div>

  <div class="page-wrapper">
    <div class="page">

      {!order ? (
        <div class="error-page">
          <svg width="48" height="48" fill="none" stroke="#d1d5db" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <h2>Commande introuvable</h2>
          <p>Le numéro de commande <strong>{numero}</strong> n'existe pas dans le système.</p>
          <a href="/admin/orders" style="margin-top:8px; color:#166534; font-weight:600;">← Retour aux commandes</a>
        </div>
      ) : (
        <>
          <!-- Header -->
          <div class="header">
            <div>
              <div class="company-name">TOGOLESE</div>
              <div class="company-tagline">Vente et distribution</div>
            </div>
            <div class="company-contact">
              <div>Kégué derrière l'hôtel O'Balkan, Lomé - TOGO</div>
              <div><strong>Tél :</strong> +228 90 22 64 91</div>
              <div><strong>Email :</strong> Contact@togolesegroup.com</div>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Document title row -->
          <div class="doc-title-row">
            <div style="display:flex; flex-direction:column; align-items:center; gap:10px;">
              <span class="doc-badge">Bon de livraison</span>
              <span class="order-number-badge">{order.order_number}</span>
            </div>
            <div class="doc-date">
              <span style="font-size:10.5px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Date de livraison</span>
              <strong>{todayStr}</strong>
            </div>
          </div>

          <!-- Info grid: client | livraison -->
          <div class="info-grid">
            <div class="info-box">
              <div class="info-box-header">Informations client</div>
              <div class="info-box-body">
                <div class="label">Nom</div>
                <div class="value big">{order.client_name}</div>
                <div style="margin-top:8px;">
                  <div class="label">Téléphone</div>
                  <div class="value">{order.client_phone}</div>
                </div>
                {order.notes && (
                  <div style="margin-top:8px;">
                    <div class="label">Notes</div>
                    <div class="value" style="font-size:12px; font-weight:500; color:#4b5563;">{order.notes}</div>
                  </div>
                )}
              </div>
            </div>
            <div class="info-box">
              <div class="info-box-header">Détails livraison</div>
              <div class="info-box-body">
                <div class="label">Mode de livraison</div>
                <div class="value" style="margin-top:2px;">
                  <span class={`delivery-badge ${order.delivery_type === 'avion' ? 'delivery-avion' : 'delivery-bateau'}`}>
                    {order.delivery_type === 'avion' ? 'EXPRESS (avion)' : 'ECONOMIQUE (bateau)'}
                  </span>
                </div>
                <div style="margin-top:10px;">
                  <div class="label">Date de commande</div>
                  <div class="value" style="font-size:12px;">{dateStr(order.created_at!)}</div>
                </div>
                <div style="margin-top:10px;">
                  <div class="label">Montant total</div>
                  <div class="value" style="font-size:13px; color:#166534;">{fmt(order.total_amount)} FCFA</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Products table -->
          <div class="section-title">Articles livrés</div>
          <table>
            <thead>
              <tr>
                <th>Qté</th>
                <th>Description / Produit</th>
                <th style="text-align:right;">Total</th>
              </tr>
            </thead>
            <tbody>
              {(order.products ?? []).length === 0 ? (
                <tr>
                  <td colspan="3" style="text-align:center; color:#9ca3af; font-style:italic; padding:20px;">
                    Aucun produit enregistré
                  </td>
                </tr>
              ) : (
                (order.products ?? []).map((product) => (
                  <tr>
                    <td>{product.quantity}</td>
                    <td>
                      <div class="product-name">{product.name}</div>
                      {product.condition && <div class="product-condition">{product.condition}</div>}
                    </td>
                    <td>{fmt(product.price * product.quantity)} FCFA</td>
                  </tr>
                ))
              )}
            </tbody>
            {(order.products ?? []).length > 0 && (
              <tfoot>
                <tr>
                  <td>{(order.products ?? []).reduce((s, p) => s + p.quantity, 0)}</td>
                  <td>TOTAL ARTICLES</td>
                  <td>{fmt(order.total_amount)} FCFA</td>
                </tr>
              </tfoot>
            )}
          </table>

          <!-- Signature section -->
          <div class="signature-section">
            <div class="signature-box">
              <div class="signature-box-title">Signature du client</div>
              <div class="signature-line"></div>
              <div class="date-line">Date : _____ / _____ / _________</div>
              <div class="signature-box-hint">Je soussigné(e) atteste avoir reçu les articles ci-dessus en bon état.</div>
            </div>
            <div class="signature-box">
              <div class="signature-box-title">Cachet &amp; Signature TOGOLESE</div>
              <div class="signature-line"></div>
              <div class="date-line">Remis par : ________________________________</div>
              <div class="signature-box-hint">Représentant(e) TOGOLESE</div>
            </div>
          </div>

          <!-- Footer -->
          <div class="footer">
            <strong>Merci pour votre confiance !</strong>
            TOGOLESE &mdash; Kégué derrière l'hôtel O'Balkan, Lomé - TOGO &mdash; Contact@togolesegroup.com
          </div>
        </>
      )}

    </div>
  </div>

</body>
</html>
