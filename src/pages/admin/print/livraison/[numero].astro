        border-radius: 4px !important; margin-top: 8px !important;
      }
      .doc-date { font-size: 11px !important; color: #111 !important; text-align: right !important; }
      .doc-date strong { font-size: 12px !important; color: #111 !important; }

      /* ══ INFO GRID ══ */
      .info-grid { display: grid !important; grid-template-columns: 1fr 1fr !important; gap: 14px !important; margin-bottom: 18px !important; }
      .info-box { border: 1px solid #111 !important; border-radius: 6px !important; overflow: hidden !important; }
      .info-box-header {
        background: #f8fafc !important; border-bottom: 1px solid #111 !important;
        padding: 6px 12px !important; font-size: 9px !important; font-weight: 800 !important;
        text-transform: uppercase !important; letter-spacing: 1.2px !important; color: #111 !important;
      }
      .info-box-body { padding: 10px 12px !important; line-height: 1.8 !important; }
      .info-box-body .label { font-size: 9.5px !important; color: #111 !important; font-weight: 600 !important; text-transform: uppercase !important; }
