---
import { requireAuth } from '../../../lib/auth';
import { getOrderByNumber, getPaymentsByOrderId } from '../../../lib/orders';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const { numero } = Astro.params;
const order = numero ? getOrderByNumber(numero) : null;
const payments = order?.id ? getPaymentsByOrderId(order.id) : [];

const fmt = (n: number) => n.toLocaleString('fr-FR');
const dateStr = (d: string) => new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });

const statusLabel: Record<string, string> = {
  en_attente: 'En attente',
  disponible: 'Disponible',
  recupere: 'Récupéré',
};

// Estimated delivery: 14 days for air, 45 days for sea
const deliveryDays = order?.delivery_type === 'avion' ? 14 : 45;
const estimatedDeliveryStr = order
  ? dateStr(new Date(new Date(order.created_at!).getTime() + deliveryDays * 24 * 60 * 60 * 1000).toISOString())
  : '';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bon de commande {order?.order_number ?? 'introuvable'}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
      font-size: 13px;
      color: #111;
      background: #f3f4f6;
    }

    /* Print action bar */
    .no-print {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #1e40af;
      padding: 10px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    .no-print button {
      background: #fff;
      color: #1e40af;
      border: none;
      border-radius: 6px;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .no-print button:hover { background: #e0e7ff; }
    .no-print a {
      color: #bfdbfe;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
    }
    .no-print a:hover { color: #fff; }
    .no-print .spacer { flex: 1; }
    .no-print .hint { color: #93c5fd; font-size: 12px; }

    /* A4 page wrapper */
    .page-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 16px 48px;
      gap: 0;
    }

    .page {
      background: #fff;
      width: 100%;
      max-width: 800px;
      min-height: 1100px;
      padding: 40px 48px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      border-radius: 4px;
      display: flex;
      flex-direction: column;
    }
    .page-content { flex: 1; }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 6px;
    }
    .company-name {
      font-size: 30px;
      font-weight: 900;
      color: #1e40af;
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .company-tagline {
      font-size: 11px;
      color: #111;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-top: 4px;
      text-align: center;
    }
    .company-contact {
      text-align: right;
      font-size: 11.5px;
      color: #111;
      line-height: 1.7;
    }
    .company-contact strong { color: #1e40af; font-weight: 700; }

    /* Separator */
    .divider {
      height: 3px;
      background: linear-gradient(90deg, #1e40af 0%, #3b82f6 60%, #bfdbfe 100%);
      border-radius: 2px;
      margin: 14px 0;
    }

    /* Document title row */
    .doc-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .doc-badge {
      display: inline-flex;
      align-items: center;
      background: #1e40af;
      color: #fff;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 1.5px;
      padding: 8px 18px;
      border-radius: 6px;
      text-transform: uppercase;
    }
    .order-number-badge {
      font-family: 'Courier New', Courier, monospace;
      font-size: 15px;
      font-weight: 700;
      color: #1e40af;
      background: #eff6ff;
      border: 1.5px solid #bfdbfe;
      padding: 5px 12px;
      border-radius: 5px;
      letter-spacing: 0.5px;
      margin-top: 10px;
    }
    .doc-date {
      font-size: 12px;
      color: #111;
      text-align: right;
    }
    .doc-date strong {
      display: block;
      font-size: 13.5px;
      color: #111;
    }

    /* Info grid */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 22px;
    }
    .info-box {
      border: 1px solid #111;
      border-radius: 6px;
      overflow: hidden;
    }
    .info-box-header {
      background: #f8fafc;
      border-bottom: 1px solid #111;
      padding: 7px 14px;
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #111;
    }
    .info-box-body {
      padding: 12px 14px;
      line-height: 1.8;
    }
    .info-box-body .label {
      font-size: 10.5px;
      color: #111;
      font-weight: 600;
      text-transform: uppercase;
    }
    .info-box-body .value {
      font-size: 13px;
      color: #111;
      font-weight: 600;
    }
    .info-box-body .value.big {
      font-size: 15px;
      font-weight: 700;
      color: #1e40af;
      text-transform: uppercase;
    }
    .delivery-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
    }
    .delivery-avion { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .delivery-bateau { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .status-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      background: #fefce8;
      color: #854d0e;
      border: 1px solid #fde68a;
    }
    .status-disponible { background: #f0fdf4; color: #166534; border-color: #bbf7d0; }
    .status-recupere   { background: #f9fafb; color: #4b5563; border-color: #e5e7eb; }

    /* Products table */
    .section-title {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #111;
      margin-bottom: 8px;
      padding-bottom: 4px;
      border-bottom: 1px solid #111;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      font-size: 12.5px;
    }
    thead tr { background: #1e40af; color: #fff; }
    thead th {
      padding: 9px 12px;
      text-align: left;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    thead th:last-child, thead th:nth-child(3) { text-align: center; }
    thead th:nth-child(1) { text-align: center; width: 44px; }
    tbody tr:nth-child(even) { background: #f8fafc; }
    tbody tr:nth-child(odd)  { background: #fff; }
    tbody td {
      padding: 9px 12px;
      border-bottom: 1px solid #111;
      vertical-align: middle;
      color: #111;
    }
    tbody td:first-child { text-align: center; color: #111; font-weight: 600; }
    tbody td:nth-child(3), tbody td:last-child { text-align: center; vertical-align: middle; font-weight: 600; color: #111; }
    tfoot tr { background: #eff6ff; }
    tfoot td {
      padding: 9px 12px;
      font-weight: 700;
      color: #1e40af;
      text-align: right;
      font-size: 13px;
      border-top: 2px solid #bfdbfe;
    }
    tfoot td:first-child { text-align: center; }
    tfoot td:nth-child(2) { text-align: left; }
    .product-name { font-weight: 600; color: #111; }
    .product-condition { font-size: 10.5px; color: #111; margin-top: 1px; }

    /* Financial summary */
    .summary-wrapper {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
    }
    .summary-box {
      min-width: 280px;
      max-width: 340px;
      border: 1.5px solid #111;
      border-radius: 8px;
      overflow: hidden;
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 16px;
      border-bottom: 1px solid #111;
      font-size: 12.5px;
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-label { color: #111; font-weight: 500; }
    .summary-value { font-weight: 700; color: #111; }
    .summary-row.total-row { background: #f8fafc; font-size: 13.5px; }
    .summary-row.total-row .summary-label { color: #111; font-weight: 700; }
    .summary-row.paid-row .summary-value { color: #059669; }
    .summary-row.remaining-positive .summary-value { color: #dc2626; }
    .summary-row.remaining-zero .summary-value { color: #059669; }
    .summary-row.remaining-row { background: #fef2f2; }
    .summary-row.remaining-zero-row { background: #f0fdf4; }

    /* Payments history */
    .payments-section { margin-bottom: 20px; }
    .payments-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .payments-table th {
      background: #f8fafc;
      padding: 7px 12px;
      text-align: left;
      font-size: 10.5px;
      font-weight: 700;
      color: #111;
