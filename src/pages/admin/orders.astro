<style>
  .filter-btn { border-color: #e5e7eb; color: #6b7280; background: white; }
  .filter-btn.active { border-color: #2563eb; color: #2563eb; background: #eff6ff; }
  .filter-btn:hover:not(.active) { background: #f9fafb; }

</style>

<script>
// ---- Helpers ----
function esc(str: unknown): string {
  return String(str ?? '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function fmt(n: number) {
  return Number(n).toLocaleString('fr-FR');
}

// ---- Filter + Search ----
let activeStatus = 'all';

function applyFilters() {
  const search = (document.getElementById('search-input') as HTMLInputElement).value.toLowerCase().trim();

  let visible = 0;
  document.querySelectorAll('.order-row').forEach(row => {
    const r = row as HTMLElement;
    const status = r.dataset.status ?? '';
    const client = r.dataset.client ?? '';
    const number = r.dataset.number ?? '';

    const matchStatus = activeStatus === 'all' || status === activeStatus;
    const matchSearch = !search || client.includes(search) || number.includes(search);

    const show = matchStatus && matchSearch;
    r.style.display = show ? '' : 'none';
    if (show) visible++;
  });

  const countEl = document.getElementById('search-count')!;
  countEl.textContent = `${visible} commande${visible !== 1 ? 's' : ''} trouvée${visible !== 1 ? 's' : ''}`;
  countEl.classList.toggle('hidden', !search);
}

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeStatus = btn.getAttribute('data-filter') ?? 'all';
    applyFilters();
  });
});

document.getElementById('search-input')?.addEventListener('input', applyFilters);


// ---- View Modal ----
const viewModal = document.getElementById('view-modal')!;
const viewContent = document.getElementById('view-modal-content')!;

document.querySelectorAll('.view-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const order = JSON.parse(btn.getAttribute('data-order')!);
    const statusMap: Record<string, string> = {
      en_attente: '⏳ En attente',
      disponible: '✅ Disponible',
      recupere: '📦 Récupéré',
    };
    const productsHtml = (order.products ?? []).map((p: any) => `
      <div class="flex items-start justify-between py-2 border-b border-gray-50 last:border-0">
        <div>
          <span class="font-medium text-gray-900">${esc(p.name)}</span>
          <span class="text-gray-400 text-xs ml-2">${esc(p.condition)}</span>
        </div>
        <div class="text-right text-xs text-gray-600 shrink-0 ml-4">
          ${esc(p.quantity)} × ${fmt(p.price)} = <strong>${fmt(p.quantity * p.price)} FCFA</strong>
        </div>
      </div>
    `).join('');

    // Fetch payment history
    let paymentsHtml = '';
    try {
      const res = await fetch(`/api/orders/${order.id}/payments`);
      if (res.ok) {
        const payments: any[] = await res.json();
        if (payments.length > 0) {
          paymentsHtml = `
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Historique des paiements</p>
              <div class="bg-gray-50 rounded-xl divide-y divide-gray-100">
                ${payments.map((p, i) => `
                  <div class="flex items-center justify-between px-4 py-2.5 text-sm">
                    <div>
                      <span class="font-medium text-gray-700">Paiement #${i + 1}</span>
                      <span class="text-xs text-gray-400 ml-2">${new Date(p.created_at).toLocaleDateString('fr-FR', {day:'2-digit',month:'short',year:'numeric'})}</span>
                      ${p.payment_method ? `<span class="ml-2 text-xs bg-white border border-gray-200 px-1.5 py-0.5 rounded text-gray-600">${esc(p.payment_method)}</span>` : ''}
                      ${p.performed_by ? `<span class="ml-2 text-xs text-blue-600 font-medium">par ${esc(p.performed_by)}</span>` : ''}
                    </div>
                    <span class="font-bold text-green-600">+${fmt(p.amount)} FCFA</span>
                  </div>
                `).join('')}
              </div>
            </div>
          `;
        }
      }
    } catch {}

    viewContent.innerHTML = `
      <div class="space-y-4">
        <div class="flex items-center justify-between pb-3 border-b border-gray-100">
          <span class="font-mono text-sm font-bold text-blue-700 bg-blue-50 px-3 py-1 rounded-lg">${esc(order.order_number)}</span>
          <span class="text-xs text-gray-400">${new Date(order.created_at).toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'})}</span>
        </div>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <div><span class="text-gray-400 text-xs block">Client</span><span class="font-semibold">${esc(order.client_name)}</span></div>
          <div><span class="text-gray-400 text-xs block">WhatsApp</span><span class="font-mono">${esc(order.client_phone)}</span></div>
          <div><span class="text-gray-400 text-xs block">Livraison</span><span>${order.delivery_type === 'avion' ? '✈️ EXPRESS' : '🚢 ECO'}</span></div>
          <div><span class="text-gray-400 text-xs block">Statut</span><span>${esc(statusMap[order.status] ?? order.status)}</span></div>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Produits</p>
          <div class="bg-gray-50 rounded-xl px-4 py-1">${productsHtml}</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Montant total</span><span class="font-bold">${fmt(order.total_amount)} FCFA</span></div>
          <div class="flex justify-between"><span class="text-gray-500">Total versé</span><span class="text-green-600">− ${fmt(order.deposit)} FCFA</span></div>
          <div class="flex justify-between pt-2 border-t border-gray-200 font-bold">
            <span>Reste à payer</span>
            <span class="${Number(order.remaining_balance) > 0 ? 'text-red-600' : 'text-green-600'}">${fmt(order.remaining_balance)} FCFA</span>
          </div>
        </div>
        ${paymentsHtml}
