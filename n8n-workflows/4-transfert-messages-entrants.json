    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst entry = body?.entry?.[0];\nconst change = entry?.changes?.[0];\nconst value = change?.value;\nconst message = value?.messages?.[0];\n\n// Ignorer si pas de message texte\nif (!message) return [];\n\nconst from = message.from;\nconst name = value?.contacts?.[0]?.profile?.name || from;\nconst timestamp = new Date(parseInt(message.timestamp) * 1000)\n  .toLocaleString('fr-FR', { timeZone: 'Africa/Lome', day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });\n\nlet texte = '';\nif (message.type === 'text') {\n  texte = message.text.body;\n} else if (message.type === 'image') {\n  texte = '[Image reçue]';\n} else if (message.type === 'audio') {\n  texte = '[Message vocal reçu]';\n} else if (message.type === 'video') {\n  texte = '[Vidéo reçue]';\n} else if (message.type === 'document') {\n  texte = '[Document reçu]';\n} else {\n  texte = `[Message de type : ${message.type}]`;\n}\n\nconst forwarded = `📩 *Nouveau message client*\\n\\n👤 *${name}*\\n📞 +${from}\\n🕐 ${timestamp}\\n\\n💬 ${texte}`;\n\nreturn [{ json: { from, name, timestamp, texte, forwarded } }];"
      },
