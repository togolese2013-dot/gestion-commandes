// ---- Payment Modal ----
const paymentModal = document.getElementById('payment-modal')!;
const payAmountInput = document.getElementById('pay-amount') as HTMLInputElement;
const payError = document.getElementById('pay-error')!;
let paymentOrderId: string | null = null;
let paymentRemaining = 0;

document.querySelectorAll('.payment-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    paymentOrderId = btn.getAttribute('data-id');
    paymentRemaining = parseFloat(btn.getAttribute('data-remaining') ?? '0');
    document.getElementById('pay-client-name')!.textContent = btn.getAttribute('data-name') ?? '';
    document.getElementById('pay-order-number')!.textContent = btn.getAttribute('data-number') ?? '';
    document.getElementById('pay-total')!.textContent = fmt(parseFloat(btn.getAttribute('data-total') ?? '0')) + ' FCFA';
    document.getElementById('pay-deposit')!.textContent = fmt(parseFloat(btn.getAttribute('data-deposit') ?? '0')) + ' FCFA';
    document.getElementById('pay-remaining')!.textContent = fmt(paymentRemaining) + ' FCFA';
    payAmountInput.value = '';
    payAmountInput.max = String(paymentRemaining);
    payError.classList.add('hidden');
    paymentModal.classList.remove('hidden');
    payAmountInput.focus();
  });
});

document.getElementById('pay-full-btn')!.addEventListener('click', () => {
  payAmountInput.value = String(paymentRemaining);
});

document.getElementById('close-payment-modal')!.addEventListener('click', () => paymentModal.classList.add('hidden'));
document.getElementById('cancel-payment')!.addEventListener('click', () => paymentModal.classList.add('hidden'));
paymentModal.addEventListener('click', e => { if (e.target === paymentModal) paymentModal.classList.add('hidden'); });

document.getElementById('do-payment')!.addEventListener('click', async () => {
  const amount = parseFloat(payAmountInput.value);
  if (!amount || amount <= 0 || amount > paymentRemaining) {
    payError.textContent = 'Montant invalide ou supérieur au reste à payer.';
    payError.classList.remove('hidden');
    return;
  }
  payError.classList.add('hidden');
  const doBtn = document.getElementById('do-payment') as HTMLButtonElement;
  const spinner = document.getElementById('pay-spinner')!;
  const label = document.getElementById('pay-btn-label')!;
  doBtn.disabled = true;
  spinner.classList.remove('hidden');
  label.classList.add('hidden');

  const payMethod = (document.getElementById('pay-method') as HTMLSelectElement).value;
  const res = await fetch(`/api/orders/${paymentOrderId}/payment`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ amount, payment_method: payMethod }),
  });

  doBtn.disabled = false;
  spinner.classList.add('hidden');
  label.classList.remove('hidden');

  if (res.ok) {
    paymentModal.classList.add('hidden');
    window.location.reload();
  } else {
    payError.textContent = 'Erreur lors de l\'enregistrement du paiement.';
    payError.classList.remove('hidden');
  }
});

