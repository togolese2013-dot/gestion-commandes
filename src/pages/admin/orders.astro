---
import { requireAuth } from '../../lib/auth';
import { getAllOrders } from '../../lib/orders';
import Layout from '../../layouts/Layout.astro';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const orders = getAllOrders();

const statusLabel: Record<string, string> = {
  en_attente: 'En attente',
  disponible: 'Disponible',
  recupere: 'Récupéré',
};

const statusColor: Record<string, string> = {
  en_attente: 'bg-yellow-100 text-yellow-800',
  disponible: 'bg-green-100 text-green-800',
  recupere: 'bg-gray-100 text-gray-600',
};
---

<Layout title="Gestion des commandes" isAdmin={true}>
  <div class="space-y-6">

    <!-- Header -->
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Commandes</h1>
        <p class="text-sm text-gray-500 mt-0.5">{orders.length} commande{orders.length !== 1 ? 's' : ''} au total</p>
      </div>
      <div class="flex items-center gap-2">
        <a
          href="/api/orders/export?format=xlsx"
          class="flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-3 py-2.5 rounded-lg transition-colors shadow-sm"
          title="Exporter en Excel"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          <span class="hidden sm:inline">Excel</span>
        </a>
        <a
          href="/api/orders/export?format=csv"
          class="flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-3 py-2.5 rounded-lg transition-colors shadow-sm"
          title="Exporter en CSV"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          <span class="hidden sm:inline">CSV</span>
        </a>
        <button
          id="notify-btn"
          class="flex items-center gap-1.5 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-3 py-2.5 rounded-lg transition-colors shadow-sm"
          title="Marquer les commandes en attente comme disponibles"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="hidden sm:inline">Notifier disponible</span>
          <span id="notify-count" class="hidden bg-white/30 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"></span>
        </button>
        <button
          id="remind-btn"
          class="flex items-center gap-1.5 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-3 py-2.5 rounded-lg transition-colors shadow-sm"
          title="Envoyer un rappel aux clients dont la commande est disponible depuis 3+ jours"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="hidden sm:inline">Rappels</span>
          <span id="remind-count" class="hidden bg-white/30 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"></span>
        </button>
        <a
          href="/admin"
          class="flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-3 py-2.5 rounded-lg transition-colors shadow-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          <span class="hidden sm:inline">Nouvelle commande</span>
        </a>
      </div>
    </div>

    <!-- Status Filters -->
    <div class="flex gap-2 flex-wrap">
      {[
        { key: 'all', label: `Toutes`, count: orders.length },
        { key: 'en_attente', label: 'En attente', count: orders.filter(o => o.status === 'en_attente').length },
        { key: 'disponible', label: 'Disponible', count: orders.filter(o => o.status === 'disponible').length },
        { key: 'recupere', label: 'Récupéré', count: orders.filter(o => o.status === 'recupere').length },
      ].map(f => (
        <button
          class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium border transition-all ${f.key === 'all' ? 'active' : ''}`}
          data-filter={f.key}
        >
          {f.label}
          <span class="ml-1.5 bg-black/10 px-1.5 py-0.5 rounded-full text-xs">{f.count}</span>
        </button>
      ))}
    </div>

    <!-- Search -->
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Rechercher par client ou numéro de commande..."
        class="w-full pl-9 pr-3 py-2.5 border border-gray-300 rounded-xl text-sm bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>
    <p id="search-count" class="text-xs text-gray-400 -mt-4 hidden"></p>

    {orders.length === 0 ? (
      <div class="text-center py-20 bg-white rounded-2xl border border-gray-200">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="font-semibold text-gray-700 text-lg">Aucune commande</p>
        <p class="text-gray-400 text-sm mt-1 mb-5">Commencez par créer votre première commande</p>
        <a href="/admin" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Créer une commande
        </a>
      </div>
    ) : (
      <>
        <!-- Mobile cards (hidden on md+) -->
        <div class="md:hidden space-y-3">
          {orders.map(order => (
            <div
              class="order-row bg-white rounded-2xl border border-gray-200 shadow-sm p-4"
              data-status={order.status}
              data-client={order.client_name.toLowerCase()}
              data-number={order.order_number.toLowerCase()}
              data-date={order.created_at?.slice(0, 10)}
              data-total={order.total_amount}
            >
              <!-- Top row: number + status -->
              <div class="flex items-center justify-between mb-2">
                <span class="font-mono text-xs font-bold text-blue-700 bg-blue-50 px-2 py-1 rounded-md">
                  {order.order_number}
                </span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${statusColor[order.status ?? 'en_attente']}`}>
                  {statusLabel[order.status ?? 'en_attente']}
                </span>
              </div>
              <!-- Client + delivery -->
              <div class="font-semibold text-gray-900 text-sm">{order.client_name}</div>
              <div class="text-xs text-gray-400 mt-0.5 flex items-center gap-2">
                <span>{order.client_phone}</span>
                <span>·</span>
                <span>{order.delivery_type === 'avion' ? '✈️ EXPRESS' : '🚢 ECO'}</span>
                <span>·</span>
                <span>{new Date(order.created_at!).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })}</span>
              </div>
              <!-- Balance + actions -->
              <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                <div class="text-sm">
                  <span class="text-gray-500 text-xs">Reste : </span>
                  <span class={order.remaining_balance > 0 ? 'text-red-600 font-bold' : 'text-green-600 font-bold'}>
                    {order.remaining_balance.toLocaleString('fr-FR')} FCFA
                  </span>
                </div>
                <div class="flex items-center gap-1">
                  <button class="view-btn p-2 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" data-id={order.id} data-order={JSON.stringify(order)} title="Voir le détail">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  </button>
                  <button class="edit-btn p-2 text-gray-500 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" data-id={order.id} data-order={JSON.stringify(order)} title="Modifier">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </button>
                  {order.status === 'en_attente' && (
                    <button class="confirm-available-btn p-2 text-gray-500 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} title="Marquer disponible">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </button>
                  )}
                  {order.status === 'disponible' && (
                    <button class="confirm-pickup-btn p-2 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} data-number={order.order_number} data-remaining={order.remaining_balance}
                      class:list={order.remaining_balance > 0 ? 'text-gray-300 cursor-not-allowed' : 'text-gray-500 hover:text-purple-600 hover:bg-purple-50'}
                      title={order.remaining_balance > 0 ? `Solde restant : ${order.remaining_balance.toLocaleString('fr-FR')} FCFA` : 'Confirmer récupération'}>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </button>
                  )}
                  {order.remaining_balance > 0 && (
                    <button class="payment-btn p-2 text-gray-500 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} data-number={order.order_number} data-total={order.total_amount} data-deposit={order.deposit} data-remaining={order.remaining_balance} title="Enregistrer un paiement">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </button>
                  )}
                  <a
                    href={`/admin/print/${order.order_number}`}
                    target="_blank"
                    class="p-2 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors"
                    title="Facture"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                    </svg>
                  </a>
                  {order.status === 'recupere' && (
                    <a
                      href={`/admin/print/livraison/${order.order_number}`}
                      target="_blank"
                      class="p-2 text-green-600 hover:text-green-700 hover:bg-green-50 rounded-lg transition-colors"
                      title="Bon de livraison"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8"/>
                      </svg>
                    </a>
                  )}
                  <button class="delete-btn p-2 text-gray-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} data-number={order.order_number} title="Supprimer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Desktop table (hidden on mobile) -->
        <div class="hidden md:block bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">N° commande</th>
                <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Client</th>
                <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Livraison</th>
                <th class="text-right px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Total</th>
                <th class="text-right px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Reste</th>
                <th class="text-center px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Statut</th>
                <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wider">Date</th>
                <th class="px-5 py-3.5 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              {orders.map(order => (
                <tr
                  class="order-row hover:bg-gray-50/80 transition-colors group"
                  data-status={order.status}
                  data-client={order.client_name.toLowerCase()}
                  data-number={order.order_number.toLowerCase()}
                  data-date={order.created_at?.slice(0, 10)}
                  data-total={order.total_amount}
                >
                  <td class="px-5 py-4">
                    <span class="font-mono text-xs font-bold text-blue-700 bg-blue-50 px-2 py-1 rounded-md">
                      {order.order_number}
                    </span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="font-semibold text-gray-900">{order.client_name}</div>
                    <div class="text-gray-400 text-xs mt-0.5">{order.client_phone}</div>
                  </td>
                  <td class="px-5 py-4 text-gray-600">
                    {order.delivery_type === 'avion' ? '✈️ EXPRESS' : '🚢 ECO'}
                  </td>
                  <td class="px-5 py-4 text-right font-semibold text-gray-900">
                    {order.total_amount.toLocaleString('fr-FR')} FCFA
                  </td>
                  <td class="px-5 py-4 text-right">
                    <span class={order.remaining_balance > 0 ? 'text-red-600 font-semibold' : 'text-green-600 font-semibold'}>
                      {order.remaining_balance.toLocaleString('fr-FR')} FCFA
                    </span>
                  </td>
                  <td class="px-5 py-4 text-center">
                    <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${statusColor[order.status ?? 'en_attente']}`}>
                      {statusLabel[order.status ?? 'en_attente']}
                    </span>
                  </td>
                  <td class="px-5 py-4 text-gray-500 text-xs">
                    {new Date(order.created_at!).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-1 justify-end opacity-60 group-hover:opacity-100 transition-opacity">
                      <button class="view-btn p-2 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" data-id={order.id} data-order={JSON.stringify(order)} title="Voir le détail">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      </button>
                      <button class="edit-btn p-2 text-gray-500 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" data-id={order.id} data-order={JSON.stringify(order)} title="Modifier">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                      </button>
                      {order.status === 'en_attente' && (
                        <button class="confirm-available-btn p-2 text-gray-500 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} title="Marquer disponible (envoi WhatsApp)">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </button>
                      )}
                      {order.status === 'disponible' && (
                        <button class="confirm-pickup-btn p-2 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} data-number={order.order_number} data-remaining={order.remaining_balance}
                          class:list={order.remaining_balance > 0 ? 'text-gray-300 cursor-not-allowed' : 'text-gray-500 hover:text-purple-600 hover:bg-purple-50'}
                          title={order.remaining_balance > 0 ? `Solde restant : ${order.remaining_balance.toLocaleString('fr-FR')} FCFA` : 'Confirmer récupération et paiement'}>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        </button>
                      )}
                      {order.remaining_balance > 0 && (
                        <button class="payment-btn p-2 text-gray-500 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors" data-id={order.id} data-name={order.client_name} data-number={order.order_number} data-total={order.total_amount} data-deposit={order.deposit} data-remaining={order.remaining_balance} title="Enregistrer un paiement">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </button>
                      )}
                      <a
                        href={`/admin/print/${order.order_number}`}
                        target="_blank"
                        class="p-2 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors"
                        title="Facture"
                      >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                        </svg>
                      </a>
                      {order.status === 'recupere' && (
                        <a
                          href={`/admin/print/livraison/${order.order_number}`}
                          target="_blank"
                          class="p-2 text-gray-500 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors"
                          title="Bon de livraison"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
