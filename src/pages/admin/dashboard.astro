---
import { requireAuth } from '../../lib/auth';
import { getDashboardStats } from '../../lib/orders';
import Layout from '../../layouts/Layout.astro';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const stats = getDashboardStats();

function fmt(n: number) {
  return n.toLocaleString('fr-FR');
}

const statusLabel: Record<string, string> = {
  en_attente: 'En attente',
  disponible: 'Disponible',
  recupere: 'Récupéré',
};
const statusColor: Record<string, string> = {
  en_attente: 'bg-yellow-100 text-yellow-800',
  disponible: 'bg-green-100 text-green-800',
  recupere: 'bg-gray-100 text-gray-600',
};
---

<Layout title="Dashboard" isAdmin={true}>
  <div class="space-y-8">

    <!-- Header -->
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-1">Vue d'ensemble de votre activité</p>
    </div>

    <!-- KPIs financiers -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Chiffre d'affaires</p>
        <p class="text-2xl font-bold text-gray-900">{fmt(stats.chiffre_affaires)} <span class="text-sm font-medium text-gray-400">FCFA</span></p>
        <p class="text-xs text-gray-400 mt-2">Total de toutes les commandes</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Total encaissé</p>
        <p class="text-2xl font-bold text-green-600">{fmt(stats.total_encaisse)} <span class="text-sm font-medium text-gray-400">FCFA</span></p>
        <p class="text-xs text-gray-400 mt-2">Acomptes et paiements reçus</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Impayés</p>
        <p class="text-2xl font-bold text-red-500">{fmt(stats.total_impayes)} <span class="text-sm font-medium text-gray-400">FCFA</span></p>
        <p class="text-xs text-gray-400 mt-2">Reste à encaisser</p>
      </div>
    </div>

    <!-- Statuts + Livraison -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <!-- Statuts commandes -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Statut des commandes</p>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-blue-500 inline-block"></span>
              <span class="text-sm text-gray-700">Total</span>
            </div>
            <span class="text-sm font-bold text-gray-900">{stats.total}</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 inline-block"></span>
              <span class="text-sm text-gray-700">En attente</span>
            </div>
            <span class="text-sm font-bold text-yellow-700">{stats.en_attente}</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 inline-block"></span>
              <span class="text-sm text-gray-700">Disponible</span>
            </div>
            <span class="text-sm font-bold text-green-700">{stats.disponible}</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-gray-400 inline-block"></span>
              <span class="text-sm text-gray-700">Récupéré</span>
            </div>
            <span class="text-sm font-bold text-gray-600">{stats.recupere}</span>
          </div>
        </div>
      </div>

      <!-- Livraison -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Mode de livraison</p>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 bg-blue-50 rounded-xl">
            <div class="flex items-center gap-2">
              <span class="text-lg">✈️</span>
              <div>
                <p class="text-sm font-semibold text-gray-800">EXPRESS</p>
                <p class="text-xs text-gray-400">Par avion 4–14 jours</p>
              </div>
            </div>
            <span class="text-xl font-bold text-blue-700">{stats.express}</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
            <div class="flex items-center gap-2">
              <span class="text-lg">🚢</span>
              <div>
                <p class="text-sm font-semibold text-gray-800">ECO</p>
                <p class="text-xs text-gray-400">Par bateau 30–45 jours</p>
              </div>
            </div>
            <span class="text-xl font-bold text-gray-700">{stats.eco}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Commandes récentes -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <p class="text-sm font-bold text-gray-900">Commandes récentes</p>
        <a href="/admin/orders" class="text-xs text-blue-600 hover:text-blue-800 font-medium">Voir tout →</a>
      </div>
      {stats.commandes_recentes.length === 0 ? (
        <p class="text-sm text-gray-400 text-center py-8">Aucune commande</p>
      ) : (
        <div class="divide-y divide-gray-50">
          {stats.commandes_recentes.map(order => (
            <div class="flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <div>
                  <p class="text-sm font-semibold text-gray-900">{order.client_name}</p>
                  <p class="text-xs font-mono text-blue-600">{order.order_number}</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-sm font-semibold text-gray-900">{fmt(order.total_amount)} FCFA</span>
                {order.remaining_balance > 0 && (
                  <span class="text-xs text-red-500 font-medium">−{fmt(order.remaining_balance)} FCFA</span>
                )}
                <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${statusColor[order.status ?? 'en_attente']}`}>
                  {statusLabel[order.status ?? 'en_attente']}
                </span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>
</Layout>
