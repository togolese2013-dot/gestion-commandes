      background: #eff6ff;
      border-left: 3px solid #3b82f6;
      border-radius: 0 6px 6px 0;
      font-size: 11.5px;
      color: #111;
      font-style: italic;
    }
    .back-footer {
      text-align: center;
      padding-top: 20px;
      border-top: 1px solid #111;
      color: #111;
      font-size: 11px;
      margin-top: auto;
    }
    .back-footer strong { display: block; font-size: 12px; color: #111; font-weight: 700; margin-bottom: 3px; }

