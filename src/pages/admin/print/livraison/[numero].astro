</head>
<body>

  <!-- Print action bar -->
  <div class="no-print">
    <button onclick="window.print()">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Imprimer
    </button>
    <a href="/admin/orders">← Retour aux commandes</a>
    <span class="spacer"></span>
    {order && <span class="hint">Commande {order.order_number}</span>}
  </div>

  <div class="page-wrapper">

    <!-- ===== PAGE UNIQUE ===== -->
    <div class="page">

      {!order ? (
        <div class="error-page">
          <svg width="48" height="48" fill="none" stroke="#d1d5db" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <h2>Commande introuvable</h2>
          <p>Le numéro <strong>{numero}</strong> n'existe pas.</p>
          <a href="/admin/orders" style="margin-top:8px; color:#1e40af; font-weight:600;">← Retour aux commandes</a>
        </div>
      ) : (
        <>
          <div class="page-content">
          <!-- Header -->
          <div class="header">
            <div>
              <div class="company-name">TOGOLESE</div>
              <div class="company-tagline">Vente et distribution</div>
            </div>
            <div class="company-contact">
              <div>Kégué derrière l'hôtel O'Balkan, Lomé - TOGO</div>
              <div><strong>Tél :</strong> +228 90 22 64 91</div>
              <div><strong>Email :</strong> Contact@togolesegroup.com</div>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Title row -->
          <div class="doc-title-row">
            <div style="display:flex; flex-direction:column; align-items:center;">
              <span class="doc-badge">Bon de livraison</span>
              <span class="order-number-badge">{order.order_number}</span>
            </div>
            <div class="doc-date">
              <span style="font-size:10.5px; color:#111; text-transform:uppercase; letter-spacing:0.8px;">Date d'émission</span>
              <strong>{dateStr(order.created_at!)}</strong>
            </div>
          </div>

          <!-- Info grid -->
          <div class="info-grid">
            <div class="info-box">
              <div class="info-box-header">Informations client</div>
              <div class="info-box-body">
                <div class="label">Nom</div>
                <div class="value big">{order.client_name}</div>
                <div style="margin-top:8px;">
                  <div class="label">Téléphone</div>
                  <div class="value">{order.client_phone}</div>
                </div>
                {order.notes && (
                  <div style="margin-top:8px;">
                    <div class="label">Notes</div>
                    <div class="value" style="font-size:12px; font-weight:500;">{order.notes}</div>
                  </div>
                )}
              </div>
            </div>
            <div class="info-box">
              <div class="info-box-header">Livraison &amp; Statut</div>
              <div class="info-box-body">
                <div class="label">Mode de livraison</div>
                <div class="value" style="margin-top:2px;">
                  <span class={`delivery-badge ${order.delivery_type === 'avion' ? 'delivery-avion' : 'delivery-bateau'}`}>
                    {order.delivery_type === 'avion' ? 'EXPRESS' : 'ECO'}
                  </span>
                </div>
                <div style="margin-top:10px;">
                  <div class="label">Livraison prévue</div>
                  <div class="value" style="font-size:13px; font-weight:700; color:#1e40af;">{estimatedDeliveryStr}</div>
                </div>
                <div style="margin-top:10px;">
                  <div class="label">Statut</div>
                  <div class="value" style="margin-top:2px;">
                    <span class={`status-badge ${order.status === 'disponible' ? 'status-disponible' : order.status === 'recupere' ? 'status-recupere' : ''}`}>
                      {statusLabel[order.status ?? 'en_attente']}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Products table -->
          <div class="section-title">Détail des produits</div>
          <table>
            <thead>
              <tr>
                <th>Qté</th>
                <th>Description / Produit</th>
                <th>Prix unitaire</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {(order.products ?? []).length === 0 ? (
                <tr>
                  <td colspan="4" style="text-align:center; color:#111; font-style:italic; padding:20px;">
                    Aucun produit enregistré
                  </td>
                </tr>
              ) : (
                (order.products ?? []).map((p) => (
                  <tr>
                    <td>{p.quantity}</td>
                    <td>
                      <div class="product-name">{p.name}</div>
                      {p.condition && <div class="product-condition">{p.condition}</div>}
                    </td>
                    <td>{fmt(p.price)} FCFA</td>
                    <td>{fmt(p.price * p.quantity)} FCFA</td>
                  </tr>
                ))
              )}
              {/* Empty rows to always total 9 lines */}
              {Array.from({ length: Math.max(0, 9 - (order.products ?? []).length) }).map(() => (
                <tr style="height:44px;">
                  <td></td>
                  <td></td>
                  <td></td>
                  <td></td>
                </tr>
              ))}
            </tbody>
            {(order.products ?? []).length > 0 && (
              <tfoot>
                <tr>
                  <td></td>
                  <td>TOTAL</td>
                  <td></td>
                  <td>{fmt(order.total_amount)} FCFA</td>
                </tr>
              </tfoot>
            )}
          </table>

          <!-- Financial summary -->
          <div class="summary-wrapper">
            <div class="summary-box">
              <div class="summary-row total-row">
                <span class="summary-label">Montant total</span>
                <span class="summary-value">{fmt(order.total_amount)} FCFA</span>
              </div>
              <div class="summary-row paid-row">
                <span class="summary-label">Acompte versé</span>
                <span class="summary-value">{fmt(order.deposit)} FCFA</span>
              </div>
              <div class={`summary-row ${order.remaining_balance > 0 ? 'remaining-row remaining-positive' : 'remaining-zero-row remaining-zero'}`}>
                <span class="summary-label" style="font-weight:700;">Reste à payer</span>
                <span class="summary-value" style="font-size:15px;">{fmt(order.remaining_balance)} FCFA</span>
              </div>
            </div>
          </div>

          <!-- Payments history -->
          {payments.length > 0 && (
            <div class="payments-section">
              <div class="section-title">Historique des versements</div>
              <table class="payments-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Moyen de paiement</th>
                    <th>Enregistré par</th>
                    <th style="text-align:right;">Montant</th>
                  </tr>
                </thead>
                <tbody>
                  {payments.map((payment, i) => (
                    <tr>
                      <td style="color:#111; font-size:11px;">{i + 1}</td>
                      <td>{payment.created_at ? dateStr(payment.created_at) : '—'}</td>
                      <td>{payment.payment_method || '—'}</td>
                      <td>{payment.performed_by || '—'}</td>
                      <td class="amount">{fmt(payment.amount)} FCFA</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          </div>{/* end page-content */}

          <!-- Signature zone -->
          <div class="signature-section">
            <div class="signature-box">
              <div class="signature-box-title">Signature du client</div>
              <div class="signature-line"></div>
              <div class="signature-date-line">Date : _____ / _____ / _________</div>
              <div class="signature-box-hint">Je soussigné(e) atteste avoir reçu les articles ci-dessus en bon état.</div>
            </div>
            <div class="signature-box">
              <div class="signature-box-title">Cachet &amp; Signature TOGOLESE</div>
              <div class="signature-line"></div>
              <div class="signature-date-line">Remis par : ________________________________</div>
              <div class="signature-box-hint">Représentant(e) TOGOLESE</div>
            </div>
          </div>

          <!-- Footer -->
          <div class="footer">
            <strong>Merci pour votre confiance !</strong>
            TOGOLESE &mdash; Kégué derrière l'hôtel O'Balkan, Lomé - TOGO &mdash; Tél : +228 90 22 64 91 &mdash; Contact@togolesegroup.com
          </div>
        </>
      )}

    </div>

  </div>

</body>
</html>
