      thead tr { background: #1e40af !important; color: #fff !important; }
      thead th { padding: 7px 10px !important; font-size: 9.5px !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.8px !important; color: #fff !important; }
