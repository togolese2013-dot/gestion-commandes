---
import { isAuthenticated } from '../lib/auth';
import Layout from '../layouts/Layout.astro';

if (isAuthenticated(Astro.request)) {
  return Astro.redirect('/admin/orders');
}

const error = Astro.url.searchParams.get('error');
---

<Layout title="Connexion">
  <div class="min-h-[80vh] flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-md">
      <div class="text-center mb-8">
        <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Espace Admin</h1>
        <p class="text-gray-500 text-sm mt-1">Connectez-vous pour gérer les commandes</p>
      </div>

      {error && (
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
          Mot de passe incorrect. Veuillez réessayer.
        </div>
      )}

      <form action="/api/auth/login" method="POST" class="space-y-4">
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
            Mot de passe
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autofocus
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition-colors"
        >
          Se connecter
        </button>
      </form>
    </div>
  </div>
</Layout>
