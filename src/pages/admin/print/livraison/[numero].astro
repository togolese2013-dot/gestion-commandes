      gap: 16px;
      padding-top: 12px;
    }
    .signature-box {
      border: 1.5px dashed #111;
      border-radius: 6px;
      padding: 10px 14px;
      min-height: 80px;
      display: flex;
      flex-direction: column;
    }
    .signature-box-title {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #111;
      margin-bottom: 8px;
    }
    .signature-line {
      border-bottom: 1px solid #111;
      margin-top: 28px;
    }
    .signature-date-line {
      font-size: 11px;
      color: #111;
      margin-top: 6px;
    }
    .signature-box-hint {
      font-size: 10px;
      color: #111;
      font-style: italic;
      margin-top: auto;
    }

    /* Footer */
    .footer {
      text-align: center;
      padding-top: 10px;
      margin-top: 16px;
      border-top: 1px solid #111;
      color: #111;
      font-size: 11.5px;
    }
    .footer strong { display: block; font-size: 13px; color: #111; font-weight: 700; margin-bottom: 3px; }

    /* Error page */
