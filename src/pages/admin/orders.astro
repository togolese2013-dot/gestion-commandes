document.getElementById('close-remind-modal')!.addEventListener('click', () => remindModal.classList.add('hidden'));
document.getElementById('cancel-remind')!.addEventListener('click', () => remindModal.classList.add('hidden'));
remindModal.addEventListener('click', e => { if (e.target === remindModal) remindModal.classList.add('hidden'); });

document.getElementById('do-remind')!.addEventListener('click', async () => {
  const btn     = document.getElementById('do-remind') as HTMLButtonElement;
  const spinner = document.getElementById('remind-spinner')!;
  const label   = document.getElementById('remind-btn-label')!;
  btn.disabled = true;
  spinner.classList.remove('hidden');
  label.classList.add('hidden');

  try {
    const res = await fetch('/api/orders/remind-disponible', { method: 'POST' });
    const data = await res.json();
    const sent   = data.sent   as string[];
    const failed = data.failed as string[];
    remindResult.classList.remove('hidden');
    remindResult.innerHTML = `
      <div class="space-y-1">
        ${sent.length > 0 ? `<p class="text-green-700 font-semibold">✅ ${sent.length} rappel${sent.length > 1 ? 's' : ''} envoyé${sent.length > 1 ? 's' : ''}</p>` : ''}
        ${failed.length > 0 ? `<p class="text-red-600 font-semibold">❌ ${failed.length} échec : ${failed.join(', ')}</p>` : ''}
        ${sent.length > 0 ? '<p class="text-gray-400 text-xs mt-1">Prochain rappel dans 3 jours si non récupéré.</p>' : ''}
      </div>
    `;
    label.textContent = 'Terminé';
    loadReminders();
  } catch {
    remindResult.innerHTML = '<p class="text-red-600">Erreur lors de l\'envoi.</p>';
    remindResult.classList.remove('hidden');
  } finally {
    btn.disabled = false;
    spinner.classList.add('hidden');
    label.classList.remove('hidden');
  }
});
</script>
