---
import '../styles/global.css';
import { getCurrentUser } from '../lib/auth';

interface Props {
  title: string;
  isAdmin?: boolean;
}

const { title, isAdmin = false } = Astro.props;
const currentUser = isAdmin ? getCurrentUser(Astro.request) : null;
---

<!doctype html>
<html lang="fr" style="overflow-x:hidden;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Gestion Commandes</title>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900 overflow-x-hidden">
    {isAdmin && (
      <header class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 py-0">
          <div class="flex items-center justify-between h-12">
            <!-- Logo -->
            <span class="font-bold text-base text-blue-700 shrink-0">Gestion Commandes</span>
            <!-- Nav -->
            <nav class="hidden sm:flex items-center gap-4 text-sm font-medium">
              <a href="/admin/dashboard" class="text-gray-600 hover:text-blue-700 transition-colors">Dashboard</a>
              <a href="/admin" class="text-gray-600 hover:text-blue-700 transition-colors">+ Nouvelle commande</a>
              <a href="/admin/orders" class="text-gray-600 hover:text-blue-700 transition-colors">Commandes</a>
              <a href="/admin/users" class="text-gray-600 hover:text-blue-700 transition-colors">Utilisateurs</a>
            </nav>
            <!-- User + logout -->
            <div class="flex items-center gap-3 shrink-0">
              {currentUser && (
                <span class="text-xs font-medium text-gray-700">👤 {currentUser.full_name}</span>
              )}
              <form action="/api/auth/logout" method="POST">
                <button type="submit" class="text-xs text-gray-400 hover:text-red-600 transition-colors">
                  Déconnexion
                </button>
              </form>
            </div>
          </div>
          <!-- Mobile nav -->
          <nav class="flex sm:hidden items-center gap-3 text-sm font-medium pb-2 overflow-x-auto">
            <a href="/admin/dashboard" class="text-gray-600 hover:text-blue-700 transition-colors whitespace-nowrap">Dashboard</a>
            <a href="/admin" class="text-gray-600 hover:text-blue-700 transition-colors whitespace-nowrap">+ Nouvelle</a>
            <a href="/admin/orders" class="text-gray-600 hover:text-blue-700 transition-colors whitespace-nowrap">Commandes</a>
            <a href="/admin/users" class="text-gray-600 hover:text-blue-700 transition-colors whitespace-nowrap">Utilisateurs</a>
          </nav>
        </div>
      </header>
    )}
    <main class="max-w-7xl mx-auto px-3 sm:px-4 py-6 sm:py-8 w-full overflow-x-hidden">
      <slot />
    </main>
  </body>
</html>
