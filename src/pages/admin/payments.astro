---
import Layout from '../../layouts/Layout.astro';
import { requireAuth } from '../../lib/auth';
import { getDb } from '../../lib/db';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const db = getDb();

// All payments = initial deposits (on orders) + additional payments (payments table)
const payments = db.prepare(`
  SELECT
    'deposit-' || o.id  AS id,
    o.deposit            AS amount,
    o.deposit_payment_method AS payment_method,
    o.created_by         AS performed_by,
    o.created_at,
    o.order_number,
    o.client_name,
    o.client_phone,
    'acompte'            AS payment_type
  FROM orders o
  WHERE o.deposit > 0

  UNION ALL

  SELECT
    CAST(p.id AS TEXT) AS id,
    p.amount,
    p.payment_method,
    p.performed_by,
    p.created_at,
    o.order_number,
    o.client_name,
    o.client_phone,
    'paiement'           AS payment_type
  FROM payments p
  JOIN orders o ON o.id = p.order_id

  ORDER BY created_at DESC
`).all() as {
  id: string; amount: number; payment_method: string; performed_by: string;
  created_at: string; order_number: string; client_name: string; client_phone: string;
  payment_type: string;
}[];

// Group by date
const byDate = new Map<string, typeof payments>();
for (const p of payments) {
  const day = p.created_at.slice(0, 10);
  if (!byDate.has(day)) byDate.set(day, []);
  byDate.get(day)!.push(p);
}
const days = [...byDate.entries()].sort((a, b) => b[0].localeCompare(a[0]));

const grandTotal = payments.reduce((s, p) => s + p.amount, 0);
const totalToday = byDate.get(new Date().toISOString().slice(0, 10))?.reduce((s, p) => s + p.amount, 0) ?? 0;

function fmt(n: number) { return n.toLocaleString('fr-FR'); }

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

function fmtTime(iso: string) {
  return new Date(iso).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

const methodLabel: Record<string, string> = {
  especes: 'Espèces', mobile_money: 'Mobile Money', virement: 'Virement', carte: 'Carte', autre: 'Autre',
};
const methodColor: Record<string, string> = {
  especes: 'bg-green-100 text-green-700',
  mobile_money: 'bg-blue-100 text-blue-700',
  virement: 'bg-purple-100 text-purple-700',
  carte: 'bg-indigo-100 text-indigo-700',
  autre: 'bg-gray-100 text-gray-600',
};
---

<Layout title="Paiements" isAdmin={true}>
  <div class="space-y-6">

    <!-- Header -->
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Historique des paiements</h1>
      <p class="text-sm text-gray-500 mt-1">{payments.length} encaissement{payments.length > 1 ? 's' : ''} au total</p>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Total encaissé</p>
        <p class="text-xl font-bold text-green-600">{fmt(grandTotal)} <span class="text-xs font-medium text-gray-400">FCFA</span></p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Aujourd'hui</p>
        <p class="text-xl font-bold text-blue-600">{fmt(totalToday)} <span class="text-xs font-medium text-gray-400">FCFA</span></p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 col-span-2 sm:col-span-1">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Transactions</p>
        <p class="text-xl font-bold text-gray-900">{payments.length}</p>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="flex gap-2 flex-wrap items-center">
      <input id="search-input" type="text" placeholder="Rechercher un client ou N° commande…"
        class="flex-1 min-w-48 px-4 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
      <select id="method-filter"
        class="px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
        <option value="">Tous les moyens</option>
        <option value="especes">Espèces</option>
        <option value="mobile_money">Mobile Money</option>
        <option value="virement">Virement</option>
        <option value="carte">Carte</option>
        <option value="autre">Autre</option>
      </select>
    </div>

    <!-- Payments grouped by day -->
    <div id="payments-container" class="space-y-4">
      {days.map(([date, rows]) => (
        <div class="day-group" data-date={date}>
          <!-- Day header -->
          <div class="flex items-center justify-between mb-2 px-1">
            <h2 class="text-sm font-bold text-gray-700 capitalize">{fmtDate(date)}</h2>
            <span class="text-sm font-bold text-green-600">{fmt(rows.reduce((s, p) => s + p.amount, 0))} FCFA</span>
          </div>
          <!-- Rows -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="divide-y divide-gray-50">
              {rows.map(p => (
                <div class="payment-row flex items-center justify-between px-5 py-3.5 hover:bg-gray-50 transition-colors"
                  data-client={p.client_name.toLowerCase()}
                  data-order={p.order_number.toLowerCase()}
                  data-method={p.payment_method}
                  data-type={p.payment_type}>
                  <div class="flex items-center gap-3 min-w-0">
                    <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                      <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-gray-900 truncate">{p.client_name}</p>
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-xs font-mono text-blue-600">{p.order_number}</span>
                        <span class={`text-[10px] font-bold px-1.5 py-0.5 rounded-full ${p.payment_type === 'acompte' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'}`}>{p.payment_type}</span>
                        {p.performed_by && <span class="text-xs text-gray-400">· {p.performed_by}</span>}
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center gap-3 shrink-0">
                    {p.payment_method && (
                      <span class={`hidden sm:inline text-[11px] font-semibold px-2 py-0.5 rounded-full ${methodColor[p.payment_method] ?? 'bg-gray-100 text-gray-600'}`}>
                        {methodLabel[p.payment_method] ?? p.payment_method}
                      </span>
                    )}
                    <div class="text-right">
                      <p class="text-sm font-bold text-gray-900">{fmt(p.amount)} FCFA</p>
                      <p class="text-xs text-gray-400">{fmtTime(p.created_at)}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}

      {payments.length === 0 && (
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg font-medium">Aucun paiement enregistré</p>
          <p class="text-sm mt-1">Les encaissements apparaîtront ici.</p>
        </div>
      )}
    </div>

  </div>
</Layout>

<script>
  const searchInput  = document.getElementById('search-input')  as HTMLInputElement;
  const methodFilter = document.getElementById('method-filter') as HTMLSelectElement;

  function applyFilters() {
    const q      = searchInput.value.toLowerCase().trim();
    const method = methodFilter.value;

    document.querySelectorAll('.day-group').forEach(group => {
      let groupVisible = false;
      group.querySelectorAll('.payment-row').forEach(row => {
        const el = row as HTMLElement;
        const matchQ = !q || el.dataset.client!.includes(q) || el.dataset.order!.includes(q);
        const matchM = !method || el.dataset.method === method;
        const visible = matchQ && matchM;
        (el as HTMLElement).style.display = visible ? '' : 'none';
        if (visible) groupVisible = true;
      });
      (group as HTMLElement).style.display = groupVisible ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', applyFilters);
  methodFilter.addEventListener('change', applyFilters);
</script>
