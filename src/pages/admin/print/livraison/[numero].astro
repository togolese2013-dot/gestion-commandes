      .info-box-body .value.big { font-size: 13px !important; font-weight: 700 !important; color: #1e40af !important; text-transform: uppercase !important; }
      .delivery-badge { display: inline-block !important; padding: 2px 9px !important; border-radius: 20px !important; font-size: 10px !important; font-weight: 700 !important; }
      .delivery-avion  { background: #eff6ff !important; color: #1e40af !important; border: 1px solid #1e40af !important; }
