      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst query = data.query || {};\nconst body  = data.body  || {};\n\n// ── 1. Meta verification (GET) ──────────────────────────\nif (query['hub.mode'] === 'subscribe' && query['hub.challenge']) {\n  return [{ json: { type: 'verify', challenge: String(query['hub.challenge']) } }];\n}\n\n// ── 2. Incoming message (POST) ──────────────────────────\nconst message = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\nconst value   = body?.entry?.[0]?.changes?.[0]?.value;\n\nif (!message) {\n  return [{ json: { type: 'skip' } }];\n}\n\nconst from = message.from;\nconst name = value?.contacts?.[0]?.profile?.name || ('+' + from);\nconst ts   = new Date(parseInt(message.timestamp) * 1000)\n  .toLocaleString('fr-FR', {\n    timeZone: 'Africa/Lome',\n    day: '2-digit', month: '2-digit', year: 'numeric',\n    hour: '2-digit', minute: '2-digit'\n  });\n\nconst typeMap = {\n  text:     () => message.text?.body || '',\n  image:    () => '[📷 Image reçue]',\n  audio:    () => '[🎤 Message vocal reçu]',\n  video:    () => '[🎥 Vidéo reçue]',\n  document: () => '[📄 Document reçu]',\n  sticker:  () => '[Sticker reçu]',\n};\nconst texte = (typeMap[message.type] || (() => `[${message.type}]`))();\n\nconst forwarded =\n  `📩 *Message client*\\n` +\n  `👤 *${name}*  |  📞 +${from}\\n` +\n  `🕐 ${ts}\\n\\n` +\n  `💬 ${texte}`;\n\nreturn [{ json: { type: 'message', from, name, texte, forwarded } }];"
      },
      "id": "a1b2c3d4-0004-0001-0001-000000000002",
      "name": "Router",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
