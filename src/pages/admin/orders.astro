// ── Notify Available ────────────────────────────────────────────────────────
const notifyModal   = document.getElementById('notify-modal')!;
const notifyList    = document.getElementById('notify-list')!;
const notifyResult  = document.getElementById('notify-result')!;
const notifySubtitle = document.getElementById('notify-subtitle')!;
let pendingOrders: any[] = [];

async function loadDisponible() {
  try {
    const res = await fetch('/api/orders/notify-available');
    if (!res.ok) return;
    const data = await res.json();
    pendingOrders = data.orders ?? [];
    // Update button badge
    const badge = document.getElementById('notify-count')!;
    if (pendingOrders.length > 0) {
      badge.textContent = String(pendingOrders.length);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  } catch { /* silent */ }
}
loadDisponible();

document.getElementById('notify-btn')!.addEventListener('click', async () => {
  await loadDisponible();
  notifyResult.classList.add('hidden');
  notifyResult.innerHTML = '';

  if (pendingOrders.length === 0) {
    notifyList.innerHTML = '<p class="text-gray-400 text-sm text-center py-4">Aucune commande en attente à notifier.</p>';
    notifySubtitle.textContent = '0 client';
    (document.getElementById('do-notify') as HTMLButtonElement).disabled = true;
  } else {
    (document.getElementById('do-notify') as HTMLButtonElement).disabled = false;
    notifySubtitle.textContent = `${pendingOrders.length} commande${pendingOrders.length > 1 ? 's' : ''} à marquer disponible`;
    notifyList.innerHTML = pendingOrders.map((o: any) => `
      <div class="flex items-center justify-between bg-green-50 border border-green-100 rounded-xl px-4 py-2.5">
        <div>
          <p class="text-sm font-semibold text-gray-900">${esc(o.client_name)}</p>
          <p class="text-xs text-gray-400 font-mono">${esc(o.order_number)}</p>
        </div>
        <div class="text-right">
          <p class="text-xs font-mono text-gray-500">${esc(o.client_phone)}</p>
          ${Number(o.remaining_balance) > 0
            ? `<p class="text-xs text-red-500 font-semibold">Reste: ${fmt(Number(o.remaining_balance))} F</p>`
            : '<p class="text-xs text-green-600 font-semibold">Soldé ✓</p>'}
        </div>
      </div>
    `).join('');
  }

  notifyModal.classList.remove('hidden');
});

document.getElementById('close-notify-modal')!.addEventListener('click', () => notifyModal.classList.add('hidden'));
document.getElementById('cancel-notify')!.addEventListener('click', () => notifyModal.classList.add('hidden'));
notifyModal.addEventListener('click', e => { if (e.target === notifyModal) notifyModal.classList.add('hidden'); });

document.getElementById('do-notify')!.addEventListener('click', async () => {
  const btn     = document.getElementById('do-notify') as HTMLButtonElement;
  const spinner = document.getElementById('notify-spinner')!;
  const label   = document.getElementById('notify-btn-label')!;
  btn.disabled = true;
  spinner.classList.remove('hidden');
  label.classList.add('hidden');

  const done: string[]   = [];
  const failed: string[] = [];

  try {
    for (const order of pendingOrders) {
      const res = await fetch(`/api/orders/${order.id}/confirm`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'available' }),
      });
      if (res.ok) done.push(order.order_number);
      else failed.push(order.order_number);
    }

    notifyResult.classList.remove('hidden');
    notifyResult.innerHTML = `
      <div class="space-y-1">
        ${done.length > 0 ? `<p class="text-green-700 font-semibold">✅ ${done.length} commande${done.length > 1 ? 's' : ''} marquée${done.length > 1 ? 's' : ''} disponible</p>` : ''}
        ${failed.length > 0 ? `<p class="text-red-600 font-semibold">❌ ${failed.length} échec : ${failed.join(', ')}</p>` : ''}
      </div>
    `;
    label.textContent = 'Terminé';
    if (done.length > 0) setTimeout(() => window.location.reload(), 1200);
  } catch {
    notifyResult.innerHTML = '<p class="text-red-600">Erreur lors de la mise à jour.</p>';
    notifyResult.classList.remove('hidden');
  } finally {
    btn.disabled = false;
    spinner.classList.add('hidden');
    label.classList.remove('hidden');
  }
});

