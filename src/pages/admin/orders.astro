// ---- Edit Modal ----
const editModal = document.getElementById('edit-modal')!;
const editProductsList = document.getElementById('edit-products-list')!;
const editTotalInput = document.getElementById('edit-total') as HTMLInputElement;
const editDepositInput = document.getElementById('edit-deposit') as HTMLInputElement;
const editRemainingInput = document.getElementById('edit-remaining') as HTMLInputElement;

function recalcEditTotal() {
  let total = 0;
  editProductsList.querySelectorAll('.edit-p-row').forEach(row => {
    const price = parseFloat((row.querySelector('.ep-price') as HTMLInputElement).value) || 0;
    const qty = parseInt((row.querySelector('.ep-qty') as HTMLInputElement).value) || 0;
    total += price * qty;
  });
  editTotalInput.value = Math.round(total).toString();
  editRemainingInput.value = Math.max(0, total - (parseFloat(editDepositInput.value) || 0)).toFixed(0);
}

function addEditProductRow(p?: {name:string; condition:string; price:number; quantity:number}) {
  const row = document.createElement('div');
  row.className = 'edit-p-row grid grid-cols-12 gap-2 items-center bg-gray-50 rounded-xl p-2.5 border border-gray-200';
  row.innerHTML = `
    <div class="col-span-4"><input type="text" class="ep-name w-full px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" value="${esc(p?.name??'')}" placeholder="Produit..." required /></div>
    <div class="col-span-3"><input type="text" class="ep-condition w-full px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" value="${esc(p?.condition??'')}" placeholder="État..." required /></div>
    <div class="col-span-2"><input type="number" class="ep-price w-full px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" value="${p?.price??0}" min="0" step="1" /></div>
    <div class="col-span-2"><input type="number" class="ep-qty w-full px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" value="${p?.quantity??1}" min="1" /></div>
    <div class="col-span-1 flex justify-center">
      <button type="button" class="ep-remove p-1 text-gray-300 hover:text-red-500 rounded transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  `;
  row.querySelector('.ep-price')!.addEventListener('input', recalcEditTotal);
  row.querySelector('.ep-qty')!.addEventListener('input', recalcEditTotal);
  row.querySelector('.ep-remove')!.addEventListener('click', () => { row.remove(); recalcEditTotal(); });
  editProductsList.appendChild(row);
}

document.getElementById('edit-add-product')!.addEventListener('click', () => { addEditProductRow(); recalcEditTotal(); });
editDepositInput.addEventListener('input', recalcEditTotal);

document.querySelectorAll('.edit-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const order = JSON.parse(btn.getAttribute('data-order')!);
    (document.getElementById('edit-order-id') as HTMLInputElement).value = order.id;
    (document.getElementById('edit-client-name') as HTMLInputElement).value = order.client_name;
    (document.getElementById('edit-client-phone') as HTMLInputElement).value = order.client_phone;
    (document.getElementById('edit-delivery') as HTMLSelectElement).value = order.delivery_type;
    (document.getElementById('edit-status') as HTMLSelectElement).value = order.status;
    editDepositInput.value = order.deposit;
    editTotalInput.value = Math.round(Number(order.total_amount)).toString();
    editRemainingInput.value = Math.round(Number(order.remaining_balance)).toString();
    (document.getElementById('edit-notes') as HTMLTextAreaElement).value = order.notes ?? '';
    editProductsList.innerHTML = '';
    (order.products ?? []).forEach((p: any) => addEditProductRow(p));
    (document.getElementById('edit-error') as HTMLElement).classList.add('hidden');
    editModal.classList.remove('hidden');
  });
});

document.getElementById('close-edit-modal')!.addEventListener('click', () => editModal.classList.add('hidden'));
document.getElementById('cancel-edit')!.addEventListener('click', () => editModal.classList.add('hidden'));
editModal.addEventListener('click', e => { if (e.target === editModal) editModal.classList.add('hidden'); });

document.getElementById('edit-form')!.addEventListener('submit', async e => {
  e.preventDefault();
  const id = (document.getElementById('edit-order-id') as HTMLInputElement).value;
  const submitBtn = document.getElementById('edit-submit') as HTMLButtonElement;
  const submitIcon = document.getElementById('edit-submit-icon')!;
  const submitSpinner = document.getElementById('edit-submit-spinner')!;
  const errorDiv = document.getElementById('edit-error') as HTMLElement;

  submitBtn.disabled = true;
  submitIcon.classList.add('hidden');
  submitSpinner.classList.remove('hidden');
  errorDiv.classList.add('hidden');

  const products = Array.from(editProductsList.querySelectorAll('.edit-p-row')).map(row => ({
    name: (row.querySelector('.ep-name') as HTMLInputElement).value.trim(),
    condition: (row.querySelector('.ep-condition') as HTMLInputElement).value.trim(),
    price: parseFloat((row.querySelector('.ep-price') as HTMLInputElement).value) || 0,
    quantity: parseInt((row.querySelector('.ep-qty') as HTMLInputElement).value) || 1,
  }));

  const total = parseFloat(editTotalInput.value) || 0;
  const deposit = parseFloat(editDepositInput.value) || 0;

  const payload = {
    client_name: (document.getElementById('edit-client-name') as HTMLInputElement).value.trim(),
    client_phone: (document.getElementById('edit-client-phone') as HTMLInputElement).value.trim(),
    delivery_type: (document.getElementById('edit-delivery') as HTMLSelectElement).value,
    status: (document.getElementById('edit-status') as HTMLSelectElement).value,
    total_amount: total,
    deposit: deposit,
    remaining_balance: Math.max(0, total - deposit),
    notes: (document.getElementById('edit-notes') as HTMLTextAreaElement).value,
    products,
  };

  try {
    const res = await fetch(`/api/orders/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const data = await res.json();
      errorDiv.textContent = data.error ?? 'Erreur lors de la modification.';
      errorDiv.classList.remove('hidden');
    }
  } catch {
    errorDiv.textContent = 'Erreur de connexion.';
    errorDiv.classList.remove('hidden');
  } finally {
    submitBtn.disabled = false;
    submitIcon.classList.remove('hidden');
    submitSpinner.classList.add('hidden');
  }
});

// ---- Confirm Modal (shared for available, pickup, delete) ----
const confirmModal = document.getElementById('confirm-modal')!;
let confirmAction: (() => Promise<void>) | null = null;

function showConfirm(opts: {
  title: string;
  msg: string;
  btnLabel: string;
  btnColor: string;
  iconHtml: string;
  iconBg: string;
  action: () => Promise<void>;
}) {
  document.getElementById('confirm-title')!.textContent = opts.title;
  document.getElementById('confirm-msg')!.textContent = opts.msg;
  document.getElementById('confirm-btn-label')!.textContent = opts.btnLabel;
  const doBtn = document.getElementById('do-confirm') as HTMLButtonElement;
  doBtn.className = `flex-1 px-4 py-2.5 text-sm font-semibold text-white rounded-lg transition-colors flex items-center justify-center gap-2 ${opts.btnColor}`;
  document.getElementById('confirm-icon-wrap')!.className = `w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 ${opts.iconBg}`;
  document.getElementById('confirm-icon-wrap')!.innerHTML = opts.iconHtml;
  confirmAction = opts.action;
  confirmModal.classList.remove('hidden');
}

document.getElementById('cancel-confirm')!.addEventListener('click', () => confirmModal.classList.add('hidden'));
confirmModal.addEventListener('click', e => { if (e.target === confirmModal) confirmModal.classList.add('hidden'); });

document.getElementById('do-confirm')!.addEventListener('click', async () => {
  if (!confirmAction) return;
  const doBtn = document.getElementById('do-confirm') as HTMLButtonElement;
  const spinner = document.getElementById('confirm-spinner')!;
  const label = document.getElementById('confirm-btn-label')!;
  doBtn.disabled = true;
  spinner.classList.remove('hidden');
  label.classList.add('hidden');
  await confirmAction();
  doBtn.disabled = false;
  spinner.classList.add('hidden');
  label.classList.remove('hidden');
});

